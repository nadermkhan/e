// FEATURE: Polymorphism — Virtual Method Tables (V-Tables) enable dynamic
// method dispatch at runtime. Methods declared on a subclass override the
// parent's implementation even when the object is referenced through a
// variable typed as the parent class.
extern func printf(format: String, ...) -> Void

class Animal {
    var health: Int

    func speak() {
        printf(format: "The Animal makes a generic noise.\n")
    }
}

class Dog : Animal {
    var tailWags: Int

    func speak() {
        printf(format: "The Dog barks! Health: %d, Tail Wags: %d\n", self.health, self.tailWags)
    }
}

func main() -> Int {
    var d = Dog()
    d.health = 100
    d.tailWags = 5

    // Upcast to the parent type. The compiler erases Dog-ness at the type
    // level, but the runtime V-Table on the heap object still points at
    // Dog_speak — so the next call dynamically resolves to the override.
    var a: Animal = d

    a.speak()

    return 0
}
