extern func printf(format: String, ...) -> Void

func main() -> Int {
    var primes = [2, 3, 5, 7, 11, 13]

    // The Compiler now knows exactly how long the array is!
    var max = primes.count - 1

    for i in 0...max {
        printf(format: "Prime #%d is %d\n", i, primes[i])
    }

    return primes.count
}
